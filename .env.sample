# --- Database ---
DATABASE_URL=postgresql://your_username@localhost:5432/language_training

# --- Auth (JWT) ---
# Generate with: openssl rand -base64 64 | tr -d '\n'
# Access and refresh MUST be different secrets.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=

# --- Payload CMS ---
# Any random string. Used to sign Payload's admin session cookies.
PAYLOAD_SECRET=
# Email of the first admin user created on initial boot.
INITIAL_ADMIN_EMAIL=

# --- Speech-check service ---
# Base URL of the Cloud Run service (or http://localhost:8000 in dev).
SPEECH_CHECK_URL=
# JSON service-account key with roles/run.invoker on the Cloud Run service.
# Leave blank in dev — the /api/speech/check route skips IAM when NODE_ENV=development.
GCP_SA_KEY=

# --- Paddle (billing) ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID=
# "sandbox" for dev, "production" for prod.
NEXT_PUBLIC_PADDLE_ENV=sandbox

# --- Google Cloud Storage (media uploads, optional in dev) ---
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS=

# to set env vars in one go, create a new env file and use heroku plugin
# heroku config:set -a language-licks $(grep -v '^#' .env | grep -v '^$' | grep -v '=$' | xargs) 